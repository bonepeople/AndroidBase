<resources>

    <style name="Theme.AndroidBase" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary</item>
        <item name="colorOnPrimary">@color/background</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary</item>
        <item name="colorOnSecondary">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/textNormal</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/textNormal</item>
        <item name="android:textColorPrimary">@color/textNormal</item>
        <item name="android:textColorSecondary">@color/textSecondary</item>
        <item name="android:textColorHint">@color/textHint</item>
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Theme.AndroidBase.Start" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_empty</item>
        <item name="postSplashScreenTheme">@style/Theme.AndroidBase</item>
    </style>

    <drawable name="statusBarBackground">@color/background</drawable>
    <drawable name="titleBarBackground">@color/background</drawable>
    <color name="titleColor">@color/textTitle</color>
</resources>