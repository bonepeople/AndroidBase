<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".module.home.HomeActivity">

    <com.bonepeople.android.widget.view.StatusBarHolder
        android:id="@+id/statusBarHolder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/pagePadding"
        android:paddingTop="24dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/statusBarHolder">

        <ImageView
            android:id="@+id/imageLogo"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:contentDescription="AndroidBase"
            android:src="@drawable/ic_launcher_foreground" />

        <TextView
            android:id="@+id/textAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="AndroidBase"
            android:textColor="@color/textTitle"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Select a sample module to get started"
            android:textColor="@color/textSecondary"
            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/textSectionTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/pagePadding"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:text="Sample Modules"
        android:textColor="@color/textHint"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingHorizontal="@dimen/pagePadding"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/textVersion"
        app:layout_constraintTop_toBottomOf="@id/textSectionTitle"
        tools:itemCount="4"
        tools:listitem="@layout/item_home_module" />

    <TextView
        android:id="@+id/textVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:textColor="@color/textHint"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@id/navigationBarHolder"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="Version 1.7.3" />

    <com.bonepeople.android.widget.view.NavigationBarHolder
        android:id="@+id/navigationBarHolder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>